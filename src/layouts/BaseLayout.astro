---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Integradata | Sistematiza y escala con datos",
  description = "Integradata ayuda a empresas a pasar de procesos manuales desordenados a operaciones sistematizadas con integracion de datos, ETL, reporteria y dashboards."
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
