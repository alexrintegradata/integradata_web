    <section id="contacto" class="section container contact-cta" data-reveal>
      <p class="kicker">Hablemos de tu operación</p>
      <h2>Comienza a sistematizar hoy y decide con confianza</h2>
      <p>Agenda una conversación con nuestro equipo para revisar tus procesos y definir una ruta de implementación clara.</p>
      <div class="contact-pills">
        <a href="mailto:contacto@integradata.cl">contacto@integradata.cl</a>
        <a href="tel:+56994323583">+56 9 9432 3583</a>
        <span>Av. Vitacura 2939, Of. 301, Las Condes, Santiago</span>
      </div>
    </section>
  </main>

  <footer class="footer container">
    <p>&copy; <span id="year"></span> Integradata. Datos ordenados, decisiones inteligentes.</p>
    <p><a href="/politicas_y_privacidad/">Políticas de privacidad</a></p>
  </footer>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Integradata",
      "url": "https://integradata.cl/",
      "email": "contacto@integradata.cl",
      "telephone": "+56 9 9432 3583",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Av. Vitacura 2939, Of. 301",
        "addressLocality": "Las Condes",
        "addressRegion": "Santiago",
        "addressCountry": "CL"
      }
    }
  </script>
  <script is:inline>
    const yearNode = document.querySelector("#year");
    const menuBtn = document.querySelector(".menu-btn");
    const nav = document.querySelector(".nav");
    const revealEls = document.querySelectorAll("[data-reveal]");
    const counters = document.querySelectorAll("[data-counter]");

    if (yearNode) yearNode.textContent = String(new Date().getFullYear());

    if (menuBtn && nav) {
      menuBtn.addEventListener("click", () => {
        nav.classList.toggle("open");
      });

      nav.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => nav.classList.remove("open"));
      });
    }

    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (reducedMotion) {
      revealEls.forEach((el) => el.classList.add("is-visible"));
      counters.forEach((counter) => {
        const value = counter.getAttribute("data-counter") || "0";
        counter.textContent = value + (value === "85" || value === "100" ? "%" : "+");
      });
    } else {
      const revealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (entry.target.classList.contains("hero-side")) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
              } else {
                entry.target.classList.remove("is-visible");
              }
              return;
            }

            if (!entry.isIntersecting) return;
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          });
        },
        { threshold: 0.15, rootMargin: "0px 0px -40px 0px" }
      );

      revealEls.forEach((el) => revealObserver.observe(el));

      const animateCounter = (node) => {
        const target = Number(node.getAttribute("data-counter") || "0");
        const suffix = target === 85 || target === 100 ? "%" : "+";
        const duration = 1100;
        const start = performance.now();

        const frame = (now) => {
          const progress = Math.min((now - start) / duration, 1);
          const value = Math.floor(progress * target);
          node.textContent = `${value}${suffix}`;
          if (progress < 1) requestAnimationFrame(frame);
        };

        requestAnimationFrame(frame);
      };

      const counterObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            animateCounter(entry.target);
            observer.unobserve(entry.target);
          });
        },
        { threshold: 0.35 }
      );

      counters.forEach((counter) => counterObserver.observe(counter));
    }

    const featureCarousel = document.querySelector("[data-feature-carousel]");

    if (featureCarousel) {
      const slides = Array.from(featureCarousel.querySelectorAll(".feature-slide"));
      const dots = Array.from(featureCarousel.querySelectorAll("[data-feature-dot]"));
      const count = slides.length;
      let activeIndex = Math.floor(count / 2);
      let dragStartX = 0;
      let dragStartIndex = 0;
      let isDragging = false;
      let suppressClick = false;

      const normalizeIndex = (value) => {
        const mod = value % count;
        return mod < 0 ? mod + count : mod;
      };

      const wrapDistance = (index, indexFloat) => {
        let d = index - indexFloat;
        if (d > count / 2) d -= count;
        if (d < -count / 2) d += count;
        return d;
      };

      const render = (indexFloat, animateEnter = false) => {
        slides.forEach((slide, index) => {
          const rel = wrapDistance(index, indexFloat);
          const relAbs = Math.abs(rel);
          const inRange = relAbs <= 2.2;

          if (!inRange) {
            slide.style.setProperty("--tx", "0px");
            slide.style.setProperty("--ty", "0px");
            slide.style.setProperty("--s", "0.62");
            slide.style.setProperty("--o", "0");
            slide.style.setProperty("--z", "0");
            slide.style.setProperty("--blur", "2px");
            slide.style.setProperty("--shade", "rgba(20, 28, 44, 0.44)");
            slide.style.setProperty("--img-filter", "saturate(0.5) brightness(0.62)");
            slide.classList.remove("is-active", "is-entering");
            return;
          }

          const side = rel < 0 ? -1 : 1;
          const depth = relAbs;
          const tx = side * (depth * 162 + Math.pow(depth, 1.16) * 12);
          const ty = depth * 18;
          const scale = Math.max(0.7, 1 - depth * 0.14);
          const opacity = Math.max(0.64, 1 - depth * 0.1);
          const zIndex = Math.round(100 - depth * 16);
          const blur = `${Math.max(0, depth * 0.85)}px`;
          const shadeAlpha = Math.min(0.52, depth * 0.14);
          const shade = `rgba(20, 28, 44, ${shadeAlpha.toFixed(3)})`;
          const imgFilter =
            depth <= 0.08
              ? "none"
              : `saturate(${Math.max(0.58, 1 - depth * 0.16).toFixed(3)}) brightness(${Math.max(0.62, 1 - depth * 0.18).toFixed(3)})`;

          slide.style.setProperty("--tx", `${tx.toFixed(2)}px`);
          slide.style.setProperty("--ty", `${ty.toFixed(2)}px`);
          slide.style.setProperty("--s", scale.toFixed(3));
          slide.style.setProperty("--o", opacity.toFixed(3));
          slide.style.setProperty("--z", String(zIndex));
          slide.style.setProperty("--blur", blur);
          slide.style.setProperty("--shade", shade);
          slide.style.setProperty("--img-filter", imgFilter);

          const isActive = relAbs < 0.45;
          slide.classList.toggle("is-active", isActive);
          if (!isActive) slide.classList.remove("is-entering");

          if (animateEnter && isActive) {
            slide.classList.add("is-entering");
            window.setTimeout(() => slide.classList.remove("is-entering"), 360);
          }
        });

        const dotIndex = normalizeIndex(Math.round(indexFloat));
        dots.forEach((dot, index) => {
          dot.classList.toggle("is-active", index === dotIndex);
        });
      };

      const goTo = (newIndex, animateEnter = true) => {
        activeIndex = normalizeIndex(newIndex);
        render(activeIndex, animateEnter);
      };

      const next = () => goTo(activeIndex + 1);

      const prev = () => goTo(activeIndex - 1);

      dots.forEach((dot, index) => {
        dot.addEventListener("click", () => goTo(index));
      });

      featureCarousel.addEventListener("pointerdown", (event) => {
        isDragging = true;
        dragStartX = event.clientX;
        dragStartIndex = activeIndex;
        suppressClick = false;
        featureCarousel.classList.add("is-dragging");
        featureCarousel.setPointerCapture(event.pointerId);
      });

      featureCarousel.addEventListener("pointermove", (event) => {
        if (!isDragging) return;
        const deltaX = event.clientX - dragStartX;
        if (Math.abs(deltaX) > 5) suppressClick = true;
        const dragProgress = -deltaX / 230;
        const floatIndex = dragStartIndex + dragProgress;
        render(floatIndex, false);
      });

      featureCarousel.addEventListener("pointerup", (event) => {
        if (!isDragging) return;
        const deltaX = event.clientX - dragStartX;
        const dragProgress = -deltaX / 230;
        const targetIndex = normalizeIndex(Math.round(dragStartIndex + dragProgress));
        goTo(targetIndex);

        isDragging = false;
        featureCarousel.classList.remove("is-dragging");
        featureCarousel.releasePointerCapture(event.pointerId);
        window.setTimeout(() => {
          suppressClick = false;
        }, 80);
      });

      featureCarousel.addEventListener("pointerleave", () => {
        if (!isDragging) return;
        isDragging = false;
        featureCarousel.classList.remove("is-dragging");
        goTo(activeIndex, false);
      });

      featureCarousel.addEventListener("pointercancel", () => {
        isDragging = false;
        featureCarousel.classList.remove("is-dragging");
        goTo(activeIndex, false);
      });

      featureCarousel.addEventListener("click", (event) => {
        if (suppressClick) return;

        const dotTarget = event.target.closest("[data-feature-dot]");
        if (dotTarget) return;

        const slideTarget = event.target.closest(".feature-slide");
        if (slideTarget) {
          const index = slides.indexOf(slideTarget);
          if (index === -1) return;
          if (index === activeIndex) {
            next();
            return;
          }
          goTo(index);
          return;
        }

        next();
      });

      featureCarousel.addEventListener("keydown", (event) => {
        if (event.key === "ArrowRight") next();
        if (event.key === "ArrowLeft") prev();
      });

      featureCarousel.setAttribute("tabindex", "0");
      render(activeIndex, false);
    }
  </script>
</BaseLayout>


