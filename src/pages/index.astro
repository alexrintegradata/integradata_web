---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <div class="page-glow glow-a"></div>
  <div class="page-glow glow-b"></div>

  <header class="header container">
    <a class="brand" href="#inicio" aria-label="Inicio Integradata">
      <img src="/logo.png" alt="Integradata" />
    </a>
    <nav class="nav" aria-label="Navegación principal">
      <a href="#inicio">Inicio</a>
      <a href="#nosotros">Nosotros</a>
      <a href="#servicios">Servicios</a>
      <a href="#proceso">Proceso</a>
      <a href="#faq">Páginas</a>
      <a class="btn btn-sm btn-cta" href="#contacto">Empezar <span>&rarr;</span></a>
    </nav>
    <button class="menu-btn" aria-label="Abrir menú">&#9776;</button>
  </header>

  <main id="inicio">
    <section class="hero-shell container">
      <div class="hero-main" data-reveal>
        <div class="welcome-pill">Integradata, tu partner tecnológico</div>
        <h1>
          Sistematiza 
          <span>tus procesos manuales</span>
        </h1>
        <p class="hero-intro">
          Ayudamos a empresas con procesos manuales desordenados a sistematizar, integrar y automatizar su operación para decidir mejor y crecer más rápido.
        </p>
        <div class="hero-actions">
          <a class="btn" href="#contacto">Comenzar</a>
          <a class="btn btn-ghost" href="#servicios">Saber más</a>
        </div>

        <img class="hero-device hero-landing-shot" src="/landing-web.webp" alt="Landing web Integradata" />

        <div class="hero-social">
          <a href="#contacto" aria-label="Facebook">
            <img class="icon-default" src="/facebook.png" alt="" />
            <img class="icon-hover" src="/facebook_color.png" alt="" />
          </a>
          <a href="#contacto" aria-label="LinkedIn">
            <img class="icon-default" src="/linkedin.png" alt="" />
            <img class="icon-hover" src="/linkedin_color.png" alt="" />
          </a>
          <a href="#contacto" aria-label="Instagram">
            <img class="icon-default" src="/instagram.png" alt="" />
            <img class="icon-hover" src="/instagram_color.png" alt="" />
          </a>
        </div>
      </div>

      <aside class="hero-side" data-reveal>
        <img class="hero-water" src="/agua.jpg" alt="Flujo visual azul Integradata" />
        <div class="hero-tags">
          <span>Integración de Datos</span>
          <span>Pipelines ETL</span>
          <span>Dashboards KPI</span>
          <span>Inteligencia de Negocio</span>
          <span>Automatización</span>
          <span>Gobierno de Datos</span>
          <span>Analítica de Crecimiento</span>
          <span>Insights con IA</span>
        </div>
      </aside>
    </section>

    <section class="ticker">
      <div class="ticker-track">
        <span>Automatización de reportes</span>
        <span>Modelado de datos</span>
        <span>Integración ETL</span>
        <span>Dashboards ejecutivos</span>
        <span>Visibilidad en tiempo real</span>
        <span>Decisiones basadas en evidencia</span>
        <span>Automatización de reportes</span>
        <span>Modelado de datos</span>
        <span>Integración ETL</span>
        <span>Dashboards ejecutivos</span>
      </div>
    </section>

    <section class="section container feature-showcase" id="features">
      <div class="feature-pill" data-reveal>Analítica y BI</div>
      <h2 data-reveal>Funciones de Analítica de Datos<br />e Inteligencia de Negocios</h2>

      <div class="feature-coverflow" data-feature-carousel data-reveal>
        <div class="feature-track" aria-live="polite">
          <article class="feature-slide" data-title="Analítica Operacional">
            <div class="card-swiper">
              <img src="/ca-dash-carrusel1.webp" class="img-fluid w-100" alt="Analítica Operacional" />
              <h4>Analítica Operacional</h4>
              <p>Visualiza el rendimiento diario de tu operación con indicadores claros para detectar desvíos y actuar rápido.</p>
              <a href="#servicios" class="feature-btn">Ver detalle <span>&rarr;</span></a>
            </div>
          </article>
          <article class="feature-slide" data-title="KPI en Tiempo Real">
            <div class="card-swiper">
              <img src="/ca-dash-carrusel2.webp" class="img-fluid w-100" alt="KPI en Tiempo Real" />
              <h4>KPI en Tiempo Real</h4>
              <p>Monitorea ventas, productividad y cumplimiento con tableros actualizados para decisiones basadas en evidencia.</p>
              <a href="#servicios" class="feature-btn">Ver detalle <span>&rarr;</span></a>
            </div>
          </article>
          <article class="feature-slide" data-title="Tableros Ejecutivos de BI">
            <div class="card-swiper">
              <img src="/ca-dash-carrusel3.webp" class="img-fluid w-100" alt="Tableros Ejecutivos de BI" />
              <h4>Tableros Ejecutivos de BI</h4>
              <p>Consolida múltiples fuentes de datos en un solo panel para gerencia, área comercial y operaciones.</p>
              <a href="#servicios" class="feature-btn">Ver detalle <span>&rarr;</span></a>
            </div>
          </article>
          <article class="feature-slide" data-title="Integración de Datos ETL">
            <div class="card-swiper">
              <img src="/ca-dash-carrusel4.webp" class="img-fluid w-100" alt="Integración de Datos ETL" />
              <h4>Integración de Datos ETL</h4>
              <p>Extrae, transforma y carga información desde ERP, CRM, API y planillas para obtener datos consistentes.</p>
              <a href="#servicios" class="feature-btn">Ver detalle <span>&rarr;</span></a>
            </div>
          </article>
          <article class="feature-slide" data-title="Inteligencia de Negocios">
            <div class="card-swiper">
              <img src="/ca-dash-carrusel5.webp" class="img-fluid w-100" alt="Inteligencia de Negocios" />
              <h4>Inteligencia de Negocios</h4>
              <p>Transforma datos en estrategias accionables con análisis comparativo, tendencias y alertas inteligentes.</p>
              <a href="#servicios" class="feature-btn">Ver detalle <span>&rarr;</span></a>
            </div>
          </article>
        </div>
        <div class="feature-dots" role="tablist" aria-label="Diapositivas de funciones">
          <button aria-label="Función 1" data-feature-dot="0"></button>
          <button aria-label="Función 2" data-feature-dot="1"></button>
          <button aria-label="Función 3" data-feature-dot="2"></button>
          <button aria-label="Función 4" data-feature-dot="3"></button>
          <button aria-label="Función 5" data-feature-dot="4"></button>
        </div>
      </div>
    </section>

    <section class="section container split">
      <div data-reveal>
        <p class="kicker">El problema que resolvemos</p>
        <h2>Si tu operación depende de planillas sueltas, estás perdiendo foco</h2>
        <p class="muted">
          La falta de estructura en los datos genera errores, retrabajo y decisiones tardías. En Integradata ordenamos el flujo de información para que cada área trabaje con una sola versión de la verdad.
        </p>
        <a class="btn btn-ghost" href="#proceso">Ver metodología</a>
      </div>
      <div class="metric-grid" data-reveal>
        <article class="metric-card">
          <strong data-counter="85">0</strong>
          <p>Reducción potencial de trabajo manual repetitivo</p>
        </article>
        <article class="metric-card">
          <strong data-counter="3">0</strong>
          <p>Etapas clave en nuestro proceso ETL</p>
        </article>
        <article class="metric-card">
          <strong data-counter="100">0</strong>
          <p>Soluciones diseñadas según objetivos del cliente</p>
        </article>
        <article class="metric-card">
          <strong data-counter="24">0</strong>
          <p>Decisiones más rápidas con información consolidada</p>
        </article>
      </div>
    </section>

    <section id="servicios" class="section container">
      <div class="section-head" data-reveal>
        <p class="kicker">Qué hacemos</p>
        <h2>Soluciones para convertir datos en ventaja competitiva</h2>
      </div>
      <div class="service-list">
        <article class="service-item" data-reveal>
          <span>01</span>
          <div>
            <h3>Data Analytics y Reportería</h3>
            <p>Dashboards interactivos y KPIs accionables para ventas, asistencia, productividad y control operacional.</p>
          </div>
        </article>
        <article class="service-item" data-reveal>
          <span>02</span>
          <div>
            <h3>Gestión e Integración de Datos</h3>
            <p>Procesos ETL para extraer, limpiar, transformar y cargar datos desde ERP, CRM, APIs, planillas y bases de datos.</p>
          </div>
        </article>
        <article class="service-item" data-reveal>
          <span>03</span>
          <div>
            <h3>Desarrollo y Automatización a Medida</h3>
            <p>Aplicaciones y paneles para sistematizar flujos internos, eliminar tareas manuales y escalar sin fricción.</p>
          </div>
        </article>
        <article class="service-item" data-reveal>
          <span>04</span>
          <div>
            <h3>Analítica con Inteligencia Artificial</h3>
            <p>Capa de IA para resumir resultados, detectar patrones y apoyar decisiones estratégicas con contexto del negocio.</p>
          </div>
        </article>
      </div>
    </section>

    <section id="proceso" class="section container process">
      <div class="section-head" data-reveal>
        <p class="kicker">Cómo trabajamos</p>
        <h2>Implementación en 3 pasos simples y efectivos</h2>
      </div>
      <div class="steps">
        <article class="step-card" data-reveal>
          <span>01</span>
          <h3>Levantamiento y diagnóstico</h3>
          <p>Mapeamos fuentes de datos, cuellos de botella y objetivos de cada área para diseñar una arquitectura útil para el negocio.</p>
        </article>
        <article class="step-card" data-reveal>
          <span>02</span>
          <h3>Integración y transformación ETL</h3>
          <p>Consolidamos la información, estandarizamos reglas y dejamos datos consistentes listos para explotar en reportería.</p>
        </article>
        <article class="step-card" data-reveal>
          <span>03</span>
          <h3>Visualización y mejora continua</h3>
          <p>Entregamos tableros claros para seguimiento en tiempo real y optimizamos continuamente según resultados.</p>
        </article>
      </div>
    </section>

    <section id="nosotros" class="section container">
      <div class="section-head" data-reveal>
        <p class="kicker">Quiénes somos</p>
        <h2>Tu partner tecnológico para crecer con orden y claridad</h2>
      </div>
      <div class="cards-3">
        <article class="info-card" data-reveal>
          <h3>Misión</h3>
          <p>Mejorar el desempeño y la rentabilidad de las organizaciones mediante inteligencia de negocio y soluciones tecnológicas personalizadas.</p>
        </article>
        <article class="info-card" data-reveal>
          <h3>Visión</h3>
          <p>Ser referentes en soluciones innovadoras y efectivas para pymes y empresas que buscan decisiones basadas en información confiable.</p>
        </article>
        <article class="info-card" data-reveal>
          <h3>Valores</h3>
          <p>Innovación, transparencia, mejora continua, trabajo colaborativo y compromiso real con cada cliente.</p>
        </article>
      </div>
    </section>

    <section id="testimonios" class="section container testimonials">
      <div class="section-head testimonials-head" data-reveal>
        <p class="kicker">Testimonial</p>
        <h2>Lo que nuestros clientes dicen sobre Integradata</h2>
      </div>

      <div class="testimonials-board" data-reveal>
        <div class="testimonials-grid">
          <article class="testimonial-card top-hover" data-reveal>
            <div class="testimonial-company">Caja Los Andes</div>
            <p>
              “Integradata se convirtió en una extensión de nuestro equipo.
